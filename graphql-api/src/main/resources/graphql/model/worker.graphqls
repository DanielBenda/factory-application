type Worker {
    id: UUID!
    name: String!
    surname: String!
    departmentId: UUID!
    workPosition: String!
}

type Query {
    workers: [Worker!]!
    workerById(id: UUID!): Worker
}

type Mutation {
    createWorker(name: String!, surname: String!, position: String!): Worker!
    deleteWorker(id: UUID!): Boolean!
}
