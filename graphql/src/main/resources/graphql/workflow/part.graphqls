type Part {
    id: UUID!
    code: String!
    material: String!
    name: String!
}

extend type Query {
    parts: [Part!]!
    part(id: UUID!): Part
}

extend type Mutation {
    createPart(input: CreatePartInput!): Part!
    updatePart(id: UUID!, input: UpdatePartInput!): Part!
    deletePart(id: UUID!): Boolean!
}

input CreatePartInput {
    code: String!
    material: String!
    name: String!
}

input UpdatePartInput {
    code: String!
    material: String!
    name: String!
}